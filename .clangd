CompileFlags:
  Add:
    - --target=x86_64-pc-windows-msvc
    - -fms-compatibility
    - -fms-extensions
    # These xwin include paths are only for local editor/LSP diagnostics.
    # Update /home/YOUR_USER/.xwin if xwin was installed somewhere else.
    - -DLSP_MODE=1
    - -I/home/YOUR_USER/.xwin/crt/include
    - -I/home/YOUR_USER/.xwin/sdk/include/shared
    - -I/home/YOUR_USER/.xwin/sdk/include/ucrt
    - -I/home/YOUR_USER/.xwin/sdk/include/um
    - -I/home/YOUR_USER/.xwin/sdk/include/winrt
